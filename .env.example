# Minervini Screener v1.0 - Environment Configuration
# Copy to .env and fill in your values

# Application
APP_NAME=Minervini Screener
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-me-to-random-string

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/minervini
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/minervini
SQLITE_URL=sqlite+aiosqlite:///./data/minervini.db

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Data Sources
# Yahoo Finance (free - no API key needed)
# AkShare (free - no API key needed)

# Polygon.io (optional - for premium US data)
POLYGON_API_KEY=

# Notifications
# Feishu Webhook
FEISHU_WEBHOOK_URL=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@minervini-screener.com
EMAIL_TO=

# Bark (iOS Push)
BARK_KEY=
BARK_SERVER=https://api.day.app

# AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview
# Or use local Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Market Settings
DEFAULT_MARKET=US
